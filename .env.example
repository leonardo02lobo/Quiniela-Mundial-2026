# External API (optional during MVP — predictions persist in localStorage for now)
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/v1

# NextAuth.js v5 — Google OAuth only
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-32-byte-base64-string

# Get these from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
